{
  "name": "aurora-music",
  "productName": "Aurora Music",
  "version": "1.2.0",
  "description": "\u6c89\u6d78\u5f0f\u97f3\u4e50\u64ad\u653e\u5668\uff0c\u878d\u5408\u5929\u6c14\u7535\u53f0\u3001\u6b4c\u8bcd\u821e\u53f0\u3001\u7c92\u5b50\u89c6\u89c9\u548c 3D \u6b4c\u5355\u67b6\u3002",
  "author": "nanjingya",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "start:mac": "env -u ELECTRON_RUN_AS_NODE electron .",
    "build:win": "electron-builder --win nsis",
    "build:win:dir": "electron-builder --win dir",
    "build:mac": "electron-builder --mac dmg zip",
    "build:mac:dir": "electron-builder --mac dir"
  },
  "build": {
    "appId": "com.nanjingya.auroramusic",
    "productName": "Aurora Music",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.js",
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "build/**/*",
      "server.js",
      "dj-analyzer.js",
      "package.json",
      "!public/index.*.html",
      "public/index.html"
    ],
    "asar": false,
    "win": {
      "executableName": "Aurora Music",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.music",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Aurora Music ${version}",
      "artifactName": "Aurora-Music-${version}-mac-${arch}.${ext}",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Aurora Music",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "include": "build/installer.nsh",
      "artifactName": "Aurora-Music-${version}-Setup.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "nanjingya",
        "repo": "Aurora-Music"
      }
    ]
  },
  "mineradio": {
    "update": {
      "provider": "github",
      "owner": "nanjingya",
      "repo": "Aurora-Music",
      "preview": true,
      "preferMirrors": true,
      "mirrors": [
        "https://gh.llkk.cc/",
        "https://ghfast.top/",
        "https://gh-proxy.com/"
      ]
    }
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3",
    "NeteaseCloudMusicApi": "^4.32.0"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "rcedit": "^5.0.2"
  }
}